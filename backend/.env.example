# Backend Environment Variables - Production
# Copy this to .env and fill in real values

# Application
APP_NAME=MediVision AI
APP_VERSION=1.0.0
DEBUG=false

# MongoDB Atlas (free tier)
# Get from: https://cloud.mongodb.com → Database → Connect → Driver → Python
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/medivision?retryWrites=true&w=majority

# JWT Secrets — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_THIS_TO_A_DIFFERENT_RANDOM_SECRET

# Redis (local or Redis Cloud free tier)
REDIS_URL=redis://localhost:6379/0

# CORS — your Vercel frontend URL
CORS_ORIGINS=["https://your-frontend.vercel.app","http://localhost:3000"]

# Optional: Cloudinary for image storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: AWS S3 for report storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1
